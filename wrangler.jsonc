{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "clone-hackernews",
	"main": "app/main.ts",
	"build": {
		"watch_dir": "./app",
		"command": "zig build -Dtarget=wasm32-wasi -Doptimize=ReleaseSmall",
	},
	"compatibility_date": "2026-03-10",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"kv_namespaces": [
		{
			"binding": "KV"
		},
	],
	"d1_databases": [
		{
			"binding": "DB",
		}
	],
	"assets": {
		"directory": "./zig-out/static",
		"binding": "ASSETS",
	},
}